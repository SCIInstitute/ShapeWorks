   <string notr="true">
QToolButton{
	border: 1px solid rgba( 0, 0, 0, 0 );
	margin: 0, 0, 0, 0;
	padding: 0, 0, 0, 0;
}

QToolButton:hover{
	background-color: rgba( 140, 140, 140, 50 );
}

QToolButton:pressed{
	border: 1px solid rgba( 100, 100, 100, 120 );
	background-color: rgba( 100, 100, 100, 200 );
}


/********************** optimize panel ***********************/

QLabel#optimize_label {
    color: white;
    font: bold;
}

QPushButton#optimize_header {
    background-color: qlineargradient(spread:pad, x1:0.5, y1:0, x2:0.5, y2:0.960227, stop:0 rgba(0, 0, 0, 0), stop:0.45 rgba(0, 0, 0, 30), stop:1 rgba(0, 0, 0, 25));
    border-radius: 3px;
}

QWidget#optimize_header_background {
    background-color: rgb( 192, 92, 0);
    border-radius: 3px;
    border: 1px solid rgb(90, 90, 90);
}

QWidget#optimize_panel {
    border-radius: 4px;
    border: 1px solid rgb(60, 60, 60);
    color: rgb(90, 90, 90);
}</string>
